[bits 32]

; Указатели на текущую и следующую задачу
current_task_esp dd 0
next_task_esp    dd 0

; Обработчик прерывания таймера (IRQ0)
timer_handler_multitasking:
    ; 1. Сохраняем контекст текущей задачи
    pusha                   ; Сохраняем EAX, ECX, EDX, EBX, ESP, EBP, ESI, EDI
    
    ; 2. Запоминаем, где остановился стек текущей задачи
    mov eax, [current_task_esp]
    mov [eax], esp          
    
    ; 3. ЛОГИКА ПЛАНИРОВЩИКА (Round Robin)
    ; В реальной ОС тут был бы поиск следующей готовой задачи
    ; Для примера просто берем заранее подготовленный указатель
    mov esp, [next_task_esp] 
    
    ; 4. Отправляем сигнал End of Interrupt (EOI) контроллеру
    mov al, 0x20
    out 0x20, al
    
    ; 5. Восстанавливаем контекст НОВОЙ задачи
    popa
    iret                    ; Возврат из прерывания в новую задачу
